{
  "$schema": "https://design-tokens.org/schema.json",
  "meta": {
    "name": "audience-lab-tools",
    "source": "Extracted from tailwind.config.ts, app/globals.css, app/layout.tsx, LoginGate.tsx, Dashboard.tsx, app/page.tsx"
  },
  "color": {
    "blueprint": { "value": "#2c4a6e", "type": "color" },
    "gridLine": { "value": "rgba(255,255,255,0.9)", "type": "color" },
    "radialHighlight": { "value": "rgba(120,160,200,0.35)", "type": "color" },
    "radialShadow": { "value": "rgba(40,70,110,0.55)", "type": "color" },
    "white": { "value": "#ffffff", "type": "color" },
    "line": { "value": "#e6e6e6", "type": "color" },
    "ink": { "value": "#1a1a1a", "type": "color" },
    "muted": { "value": "#8a8a8a", "type": "color" },
    "soft": { "value": "#fafafa", "type": "color" },
    "accent": { "value": "#2f5eff", "type": "color" },
    "check": { "value": "#6a9a78", "type": "color" },
    "placeholder": { "value": "#b5b5b5", "type": "color" },
    "scrollbar": { "value": "#e0e0e0", "type": "color" },
    "white50": { "value": "rgba(255,255,255,0.5)", "type": "color" },
    "white70": { "value": "rgba(255,255,255,0.7)", "type": "color" },
    "white40": { "value": "rgba(255,255,255,0.4)", "type": "color" }
  },
  "typography": {
    "fontFamily": {
      "sans": {
        "value": ["Inter", "system-ui", "sans-serif"],
        "type": "fontFamilies"
      }
    },
    "fontWeight": {
      "regular": { "value": "400", "type": "fontWeights", "note": "Only weight loaded; font-weight 400 !important globally — no bold" }
    },
    "letterSpacing": {
      "global": { "value": "-0.01em", "type": "letterSpacing" },
      "tight": { "value": "-0.025em", "type": "letterSpacing" }
    },
    "fontSize": {
      "xs": { "value": "9px", "type": "fontSizes" },
      "caption": { "value": "11px", "type": "fontSizes" },
      "meta": { "value": "12px", "type": "fontSizes" },
      "body": { "value": "13px", "type": "fontSizes" },
      "title": { "value": "15px", "type": "fontSizes" },
      "mobileBrand": { "value": "24px", "type": "fontSizes" },
      "hero": { "value": "48px", "type": "fontSizes" }
    },
    "lineHeight": {
      "tight": { "value": "1.25", "type": "lineHeights" },
      "snug": { "value": "1.375", "type": "lineHeights" },
      "relaxed": { "value": "1.625", "type": "lineHeights" }
    },
    "roles": {
      "heroDisplay": {
        "fontSize": "{typography.fontSize.hero}",
        "fontWeight": "{typography.fontWeight.regular}",
        "lineHeight": "{typography.lineHeight.tight}",
        "letterSpacing": "{typography.letterSpacing.tight}",
        "color": "{color.white}"
      },
      "pageTitle": {
        "fontSize": "{typography.fontSize.title}",
        "fontWeight": "{typography.fontWeight.regular}",
        "color": "{color.ink}"
      },
      "cardTitle": {
        "fontSize": "{typography.fontSize.body}",
        "fontWeight": "{typography.fontWeight.regular}",
        "color": "{color.ink}"
      },
      "body": {
        "fontSize": "{typography.fontSize.body}",
        "fontWeight": "{typography.fontWeight.regular}",
        "color": "{color.ink}"
      },
      "mutedMetadata": {
        "fontSize": "{typography.fontSize.body}",
        "fontWeight": "{typography.fontWeight.regular}",
        "color": "{color.muted}"
      },
      "navItem": {
        "fontSize": "{typography.fontSize.body}",
        "fontWeight": "{typography.fontWeight.regular}"
      }
    }
  },
  "spacing": {
    "navWidth": { "value": "208px", "type": "spacing", "class": "w-52" },
    "topBarHeight": { "value": "48px", "type": "spacing", "class": "h-12" },
    "shellMaxWidth": { "value": "1280px", "type": "spacing", "class": "max-w-[1280px]" },
    "contentMaxWidth": { "value": "48rem", "type": "spacing", "class": "max-w-3xl" },
    "pagePaddingX": { "value": "2rem", "type": "spacing", "class": "px-8" },
    "pagePaddingY": { "value": "1.5rem", "type": "spacing", "class": "py-6" },
    "cardPaddingX": { "value": "1rem", "type": "spacing", "class": "px-4" },
    "cardPaddingY": { "value": "0.75rem", "type": "spacing", "class": "py-3" },
    "loginCardMaxWidth": { "value": "420px", "type": "spacing", "class": "max-w-[420px]" },
    "loginCardPadding": { "value": "1.5rem", "type": "spacing", "class": "p-6" },
    "blueprintPaddingX": { "value": "3.5rem", "type": "spacing", "class": "px-14" },
    "blueprintPaddingY": { "value": "3rem", "type": "spacing", "class": "py-12" },
    "navGap": { "value": "0.75rem", "type": "spacing", "class": "gap-3" },
    "inputPaddingX": { "value": "0.75rem", "type": "spacing", "class": "px-3" },
    "inputPaddingY": { "value": "0.5rem", "type": "spacing", "class": "py-2" },
    "gridCell": { "value": "48px", "type": "spacing" }
  },
  "radius": {
    "lg": { "value": "0.375rem", "type": "borderRadius", "px": 6 },
    "xl": { "value": "0.5rem", "type": "borderRadius", "px": 8 },
    "2xl": { "value": "0.75rem", "type": "borderRadius", "px": 12 },
    "check": { "value": "3px", "type": "borderRadius" },
    "full": { "value": "999px", "type": "borderRadius" }
  },
  "border": {
    "width": { "value": "1px", "type": "borderWidth" },
    "color": { "value": "{color.line}", "type": "color" },
    "style": { "value": "solid", "type": "other" }
  },
  "shadow": {
    "card": { "value": "none", "type": "boxShadow" },
    "modal": { "value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "type": "boxShadow", "class": "shadow-sm", "note": "Used on modals only; cards have no shadow" }
  },
  "opacity": {
    "gridLayer": { "value": "0.07", "type": "opacity" },
    "disabled": { "value": "0.4", "type": "opacity", "class": "disabled:opacity-40" }
  },
  "motion": {
    "expandPanel": { "value": "0.28s ease-out", "type": "transition" },
    "chevron": { "value": "200ms", "type": "transition", "class": "duration-200" },
    "basketSlide": { "value": "0.35s ease-out", "type": "transition" }
  },
  "blueprint": {
    "base": "{color.blueprint}",
    "radials": "radial-gradient(ellipse 80% 60% at 20% 30%, rgba(120,160,200,0.35), transparent 55%), radial-gradient(ellipse 70% 50% at 85% 80%, rgba(40,70,110,0.55), transparent 50%)",
    "gridImage": "linear-gradient(rgba(255,255,255,0.9) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.9) 1px, transparent 1px)",
    "gridSize": "48px 48px",
    "gridOpacity": "{opacity.gridLayer}"
  },
  "separator": {
    "middleDot": { "value": " · ", "type": "other", "unicode": "U+00B7" }
  }
}
